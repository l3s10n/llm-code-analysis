Screen {
    background: transparent;
    color: #e8e3db;
}

#window-bar {
    dock: top;
    height: 1;
    margin: 0 1;
    padding: 0 1;
    background: transparent;
    color: #a8adb9;
}

#shell {
    height: 1fr;
    padding: 1 1 0 1;
    background: transparent;
}

#workspace {
    height: 1fr;
    background: transparent;
}

#left-column {
    width: 8fr;
    margin-right: 1;
    background: transparent;
}

#stream-card {
    width: 4fr;
}

.panel-frame {
    background: transparent;
    padding: 0;
}

.panel-focus {
    height: 1fr;
    margin-bottom: 1;
}

.panel-stream {
    height: 1fr;
}

.panel-log {
    height: 11;
}

.panel-title {
    height: 1;
    background: #95dfb3;
    color: #233025;
    text-style: bold;
    padding: 0 1;
}

.panel-content {
    height: 1fr;
    background: transparent;
    color: #eee7de;
    padding: 1 3 1 3;
    border-top: none;
    border-left: solid #95dfb3 35%;
    border-right: solid #95dfb3 35%;
    border-bottom: solid #95dfb3 35%;
}

.panel-scroll {
    background: transparent;
    padding: 0;
    scrollbar-size: 1 1;
}

.panel-scroll > .vertical-scrollbar {
    color: #667185;
    background: transparent;
}

.body-text {
    color: #eee7de;
}

.mono {
    text-style: none;
}

.wrap-text {
    width: 1fr;
}

#footer {
    height: 2;
    margin-top: 1;
    background: transparent;
}

#status-line {
    height: 1;
    color: #d4cec4;
    background: transparent;
}

#summary-line {
    height: 1;
    color: #8e96a6;
    background: transparent;
}
